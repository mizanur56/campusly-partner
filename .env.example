# Copy to `.env.local` and fill values as needed.
# Vite exposes ONLY vars prefixed with `VITE_` to the client bundle.
#
# Loading order (later wins):
#   .env
#   .env.local
#   .env.[mode]
#   .env.[mode].local

# ================================
# 🌐 App / Environment
# ================================
# Optional: if your code reads it explicitly (Vite already has import.meta.env.MODE)
VITE_NODE_ENV=

# ================================
# 🚀 API / Assets
# ================================
VITE_PUBLIC_APP_DOMAIN=
VITE_PUBLIC_SERVER_URL=
VITE_API_URL=
VITE_IMAGE_ACCESS_URL=
VITE_PUBLIC_IMAGE_ACCESS_URL=

# ================================
# 🔑 Third-Party Services
# ================================
VITE_PUBLIC_TINY_API_KEY=

